# juso.go.kr 도로명주소 검색 API 승인키
# (JUSO_CONFIRM_KEY / JUSO_CONFM_KEY / JUSO_API_KEY 어느 이름이든 인식)
JUSO_CONFIRM_KEY=

# 우정사업본부_도로명주소조회서비스 일반 인증키
EPOST_SERVICE_KEY=

# legacy 스크립트의 VWorld 검증 경로를 쓸 때만 필요
VWORLD_KEY=


# 우정사업본부 엔드포인트 override (기본: http://openapi.epost.go.kr:80/...)
# 운영망에서 https 응답이 확인되면 아래처럼 지정해 평문 키 전송을 피하세요.
# EPOST_ENDPOINT=https://openapi.epost.go.kr/postal/retrieveNewAdressAreaCdService/retrieveNewAdressAreaCdService/getNewAddressListAreaCd
